---
import Layout from "@layouts/Layout.astro";
---

<Layout
	title="Página no encontrada | Pavimentos Urbanos"
	description="La página solicitada no está disponible en el sitio de Pavimentos Urbanos."
	noindex={true}
>
	<section class="not-found-wrap">
		<div class="site-shell">
			<div class="not-found-card">
				<p class="section-eyebrow">404</p>
				<h1>La ruta que buscas no está disponible.</h1>
				<p>
					Puedes volver al inicio, revisar los servicios o explorar los trabajos disponibles dentro
					de la nueva presentación corporativa.
				</p>
				<div class="contact-actions" style="justify-content: center;">
					<a href="/" class="button button--primary">Ir al inicio</a>
					<a href="/servicios" class="button button--secondary">Ver servicios</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
