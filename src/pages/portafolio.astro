---
import Layout from "@layouts/Layout.astro";
import InternalPageHeader from "@components/sections/InternalPageHeader.astro";
import ProjectShowcase from "@components/sections/ProjectShowcase.astro";
import { company } from "@data/site";
---

<Layout
	title={`Portafolio | ${company.name}`}
	description="Vista complementaria del portafolio corporativo con proyectos tipo y estructura lista para crecer."
>
	<InternalPageHeader
		crumb="Portafolio"
		eyebrow="Portafolio"
		title="Vista complementaria para recorrer trabajos y referencias."
		description="Esta página funciona como acceso alternativo al portafolio, con un comportamiento más natural dentro de la navegación general del sitio."
		links={[
			{ label: "Ir a trabajos", href: "/trabajos" },
			{ label: "Ver servicios", href: "/servicios" },
			{ label: "Contactar", href: "/contacto" },
		]}
		stats={[
			{ value: "PU", label: "marca" },
			{ value: "2026", label: "presentación" },
		]}
	/>
	<ProjectShowcase />
</Layout>
