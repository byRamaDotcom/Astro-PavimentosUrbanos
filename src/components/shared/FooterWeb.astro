---
import { Picture, Image, imageConfig } from "astro:assets";
// import Icon from "astro-icon/components";
import { Icon } from "astro-icon/components";
import foto1 from "@images/img1.png";
// import { icon1 } from "@icons/brand-whatsapp.svg";
// import { Image } from "astro:assets";
---

<footer>
	<div
		class="flex-col mx-auto w-full md:max-w-4xl lg:max-w-7xl md:flex px-2 py-16 md:px-4 md:py-20">
		<div class="md:flex md:flex-row md:justify-between">
			<div>
				<Image src={foto1} alt="Logo Pavimentos Urbanos" sizes="50" />
				<p class="font-inter mt-4 max-w-80 text-base font-light text-gray-700">
					Especialistas en urbanización, pavimentación y obras civiles.
				</p>
				<!-- SOCIAL MEDIA ICONS -->
				<div class="mb-8 mt-6 flex flex-row">
					<a href="" class="mr-4 text-black transition hover:text-gray-400">
						<svg
							class="fill-current"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg">
							<path
								d="M12 2.25C9.4791 2.25005 7.05619 3.22647 5.23968 4.97439C3.42317 6.72231 2.35426 9.10586 2.25723 11.6249C2.1602 14.1439 3.0426 16.6026 4.71928 18.4851C6.39595 20.3676 8.73657 21.5275 11.25 21.7214V14.2501H9C8.80109 14.2501 8.61032 14.1711 8.46967 14.0304C8.32902 13.8898 8.25 13.699 8.25 13.5001C8.25 13.3012 8.32902 13.1104 8.46967 12.9698C8.61032 12.8291 8.80109 12.7501 9 12.7501H11.25V10.5001C11.2509 9.70472 11.5673 8.94218 12.1297 8.37977C12.6921 7.81736 13.4546 7.501 14.25 7.50009H15.75C15.9489 7.50009 16.1397 7.57911 16.2803 7.71976C16.421 7.86041 16.5 8.05118 16.5 8.25009C16.5 8.449 16.421 8.63977 16.2803 8.78042C16.1397 8.92107 15.9489 9.00009 15.75 9.00009H14.25C13.8523 9.00054 13.471 9.15872 13.1898 9.43993C12.9086 9.72114 12.7505 10.1024 12.75 10.5001V12.7501H15C15.1989 12.7501 15.3897 12.8291 15.5303 12.9698C15.671 13.1104 15.75 13.3012 15.75 13.5001C15.75 13.699 15.671 13.8898 15.5303 14.0304C15.3897 14.1711 15.1989 14.2501 15 14.2501H12.75V21.7214C15.2634 21.5275 17.604 20.3676 19.2807 18.4851C20.9574 16.6026 21.8398 14.1439 21.7427 11.6249C21.6457 9.10587 20.5768 6.72232 18.7603 4.9744C16.9438 3.22649 14.5209 2.25006 12 2.25Z"
							></path>
						</svg>
					</a>
					<a href="" class="mr-4 text-black transition hover:text-gray-400">
						<Icon name="mapIcon" />
						<!-- <Icon name="tabler:brand-instagram" size="24" />
						<Icon name="tabler:brand-facebook" size="24" />
						<Icon name="tabler:brand-linkedin" size="24" />
						<Icon name="tabler:brand-whatsapp" size="24" /> -->
						<svg
							class="fill-current"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg">
							<path
								d="M12 2.25C9.4791 2.25005 7.05619 3.22647 5.23968 4.97439C3.42317 6.72231 2.35426 9.10586 2.25723 11.6249C2.1602 14.1439 3.0426 16.6026 4.71928 18.4851C6.39595 20.3676 8.73657 21.5275 11.25 21.7214V14.2501H9C8.80109 14.2501 8.61032 14.1711 8.46967 14.0304C8.32902 13.8898 8.25 13.699 8.25 13.5001C8.25 13.3012 8.32902 13.1104 8.46967 12.9698C8.61032 12.8291 8.80109 12.7501 9 12.7501H11.25V10.5001C11.2509 9.70472 11.5673 8.94218 12.1297 8.37977C12.6921 7.81736 13.4546 7.501 14.25 7.50009H15.75C15.9489 7.50009 16.1397 7.57911 16.2803 7.71976C16.421 7.86041 16.5 8.05118 16.5 8.25009C16.5 8.449 16.421 8.63977 16.2803 8.78042C16.1397 8.92107 15.9489 9.00009 15.75 9.00009H14.25C13.8523 9.00054 13.471 9.15872 13.1898 9.43993C12.9086 9.72114 12.7505 10.1024 12.75 10.5001V12.7501H15C15.1989 12.7501 15.3897 12.8291 15.5303 12.9698C15.671 13.1104 15.75 13.3012 15.75 13.5001C15.75 13.699 15.671 13.8898 15.5303 14.0304C15.3897 14.1711 15.1989 14.2501 15 14.2501H12.75V21.7214C15.2634 21.5275 17.604 20.3676 19.2807 18.4851C20.9574 16.6026 21.8398 14.1439 21.7427 11.6249C21.6457 9.10587 20.5768 6.72232 18.7603 4.9744C16.9438 3.22649 14.5209 2.25006 12 2.25Z"
							></path>
						</svg>
					</a>
				</div>
			</div>
			<!-- FOOTER LINKS -->
			<div class="flex grow flex-row flex-wrap md:mx-6 md:flex-nowrap md:justify-center">
				<!-- LINK BLOCK -->
				<div class="my-5 mr-4 flex max-w-52 grow basis-24 flex-col space-y-5 md:mx-6 md:mt-0">
					<h2 class="font-inter font-medium text-black">SOLUTION</h2>
					<a href="" class="font-inter font-light text-gray-500"> Marketing </a>
					<a href="" class="font-inter font-light text-gray-500"> Analytics </a>
					<a href="" class="font-inter font-light text-gray-500"> Commerce </a>
					<a href="" class="font-inter font-light text-gray-500"> Insights </a>
				</div>
				<!-- LINK BLOCK -->
				<div class="my-5 mr-4 flex max-w-52 grow basis-24 flex-col space-y-5 md:mx-6 md:mt-0">
					<h2 class="font-inter font-medium text-black">SUPPORT</h2>
					<a href="" class="font-inter font-light text-gray-500"> Pricing </a>
					<a href="" class="font-inter font-light text-gray-500"> Documentation </a>
					<a href="" class="font-inter font-light text-gray-500"> Guides </a>
					<a href="" class="font-inter font-light text-gray-500"> API Status </a>
				</div>
				<!-- LINK BLOCK -->
				<div class="my-5 mr-4 flex max-w-52 grow basis-24 flex-col space-y-5 md:mx-6 md:mt-0">
					<h2 class="font-inter font-medium text-black">COMPANY</h2>
					<a href="" class="font-inter font-light text-gray-500"> About </a>
					<a href="" class="font-inter font-light text-gray-500"> Blog </a>
					<a href="" class="font-inter font-light text-gray-500"> Jobs </a>
					<a href="" class="font-inter font-light text-gray-500"> Press </a>
					<a href="" class="font-inter font-light text-gray-500"> Partners </a>
				</div>
			</div>
			<!-- LOCATION & SUPPORT -->
			<div class="mt-10 flex flex-col md:mt-0">
				<!-- ITEM -->
				<div class="mb-4 flex flex-row items-center max-w-72">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 40"
						fill="none"
						xmlns="http://www.w3.org/2000/svg">
						<path
							d="M12 12.75C13.6569 12.75 15 11.4069 15 9.75C15 8.09315 13.6569 6.75 12 6.75C10.3431 6.75 9 8.09315 9 9.75C9 11.4069 10.3431 12.75 12 12.75Z"
							stroke="black"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
						<path
							d="M19.5 9.75C19.5 16.5 12 21.75 12 21.75C12 21.75 4.5 16.5 4.5 9.75C4.5 7.76088 5.29018 5.85322 6.6967 4.4467C8.10322 3.04018 10.0109 2.25 12 2.25C13.9891 2.25 15.8968 3.04018 17.3033 4.4467C18.7098 5.85322 19.5 7.76088 19.5 9.75V9.75Z"
							stroke="black"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>

					<p class="font-inter ml-4 text-black">Casa Matriz: Santiago, Chile</p>
				</div>
				<!-- ITEM -->
				<div class="mb-4 flex flex-row items-center max-w-72">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						xmlns="http://www.w3.org/2000/svg">
						<path
							d="M3 5.25H21V18C21 18.1989 20.921 18.3897 20.7803 18.5303C20.6397 18.671 20.4489 18.75 20.25 18.75H3.75C3.55109 18.75 3.36032 18.671 3.21967 18.5303C3.07902 18.3897 3 18.1989 3 18V5.25Z"
							stroke="black"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
						<path
							d="M21 5.25L12 13.5L3 5.25"
							stroke="black"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
					<p class="font-inter ml-4 text-black">contacto@pavimentos.class</p>
				</div>
			</div>
		</div>
		<div>
			<p class="font-inter text-center text-sm text-gray-500 md:mt-0">
				© Copyright 2026. Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>
