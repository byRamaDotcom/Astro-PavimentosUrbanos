---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import logo from "@assets/LogoFull.svg";
import { company, contactChannels, navigation, services } from "@data/site";
---

<footer class="site-footer">
	<div class="site-shell">
		<div class="footer-grid">
			<div class="foot-card">
				<div class="site-brand">
					<span class="site-brand__mark">
						<Image src={logo} alt={`Logo ${company.name}`} width={54} quality="high" />
					</span>
					<span class="site-brand__copy">
						<strong>{company.name}</strong>
						<span>{company.tagline}</span>
					</span>
				</div>
				<h3>Constructora orientada a urbanización y desarrollo constructivo.</h3>
				<p>{company.description}</p>
			</div>

			<div class="footer-links">
				<h3>Navegación</h3>
				<ul>
					{
						navigation.map((item) => (
							<li>
								<a href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="footer-links">
				<h3>Servicios</h3>
				<ul>
					{
						services.map((service) => (
							<li>
								<a href={`/servicios/${service.slug}`}>{service.name}</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="footer-meta">
				<div class="footer-social">
					{
						contactChannels.map((channel) => (
							<a href={channel.href} target="_blank" rel="noreferrer" aria-label={channel.title}>
								<Icon name={channel.icon} />
							</a>
						))
					}
				</div>
			</div>
		</div>

		<div class="footer-signature">
			<p>{company.location}</p>
			<p>{company.email}</p>
			<p class="footer-note">© 2026 {company.legalName}. Todos los derechos reservados.</p>
		</div>
	</div>
</footer>
