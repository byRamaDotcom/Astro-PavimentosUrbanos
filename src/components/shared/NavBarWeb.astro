---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import logo from "@assets/LogoFull.svg";
import { company, navigation } from "@data/site";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
	href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(`${href}/`);
const navVariant = currentPath === "/" ? "home" : "interior";
---

<nav class:list={["site-nav", `site-nav--${navVariant}`]} data-nav-root>
	<div class="site-nav__bar">
		<a href="/" class="site-brand" aria-label={`Ir al inicio de ${company.name}`}>
			<span class="site-brand__mark">
				<Image src={logo} alt={`Logo ${company.name}`} width={92} quality="high" />
			</span>
			<span class="site-brand__copy">
				<strong>{company.name}</strong>
				<span>{company.tagline}</span>
			</span>
		</a>

		<div class="site-nav__links">
			{
				navigation.map(item => (
					<a href={item.href} class:list={{ active: isActive(item.href) }}>
						{item.label}
					</a>
				))
			}
		</div>

		<div class="site-nav__actions">
			<a href="/#contacto-directo" class="button button--secondary" aria-label="Contacto directo">
				<Icon name="sparkles" />
				<span class="site-nav__action-label">Contacto directo</span>
			</a>
			<a href="/contacto" class="button button--primary" aria-label="Solicitar reunión">
				<Icon name="email" />
				<span class="site-nav__action-label">Solicitar reunión</span>
			</a>
		</div>

		<details class="site-nav__mobile">
			<summary aria-label="Abrir navegación">
				<span></span>
			</summary>
			<div class="site-nav__mobile-panel">
				{
					navigation.map(item => (
						<a href={item.href} class:list={{ active: isActive(item.href) }}>
							{item.label}
						</a>
					))
				}
				<a href="/#contacto-directo" class="button button--secondary">Contacto directo</a>
				<a href="/contacto" class="button button--primary">Solicitar reunión</a>
			</div>
		</details>
	</div>
</nav>

<script>
	const cleanupKey = "__puNavbarScrollCleanup";

	function mountNavbarGlass() {
		const nav = document.querySelector("[data-nav-root]");
		if (!nav) return;

		if (typeof nav[cleanupKey] === "function") {
			nav[cleanupKey]();
		}

		let lastScrollY = window.scrollY;

		const applyState = () => {
			const currentScrollY = window.scrollY;
			const scrollDelta = currentScrollY - lastScrollY;

			nav.dataset.scrolled = currentScrollY > 24 ? "true" : "false";

			if (currentScrollY < 80) {
				nav.dataset.compact = "false";
			} else if (scrollDelta > 6) {
				nav.dataset.compact = "true";
			} else if (scrollDelta < -6) {
				nav.dataset.compact = "false";
			}

			lastScrollY = Math.max(currentScrollY, 0);
		};

		applyState();
		window.addEventListener("scroll", applyState, { passive: true });

		nav[cleanupKey] = () => {
			window.removeEventListener("scroll", applyState);
			delete nav[cleanupKey];
		};
	}

	document.addEventListener("astro:page-load", mountNavbarGlass);
	mountNavbarGlass();
</script>
