---
import { hero, heroSlides, metrics } from "@data/site";
---

<section class="hero-carousel" data-carousel>
	<div class="hero-carousel__track">
		{
			heroSlides.map((slide, index) => (
				<article
					class:list={["hero-slide", index === 0 && "is-active"]}
					data-slide
					style={`background-image: linear-gradient(180deg, rgba(10, 10, 10, 0.22), rgba(10, 10, 10, 0.58)), url('${slide.image}');`}>
					<div class="hero-slide__veil" />
					<div class="site-shell hero-slide__inner">
						<div class="hero-slide__content">
							<div class="hero-brandline">
								<span>Pavimentos</span>
								<span>Urbanos</span>
							</div>
							<p class="section-eyebrow">{hero.eyebrow}</p>
							<h1>{hero.title}</h1>
							<p class="hero-copy__lead">{hero.description}</p>
							<div class="hero-actions">
								<a href={hero.primaryCta.href} class="button button--primary">{hero.primaryCta.label}</a>
								<a href={hero.secondaryCta.href} class="button button--secondary">{hero.secondaryCta.label}</a>
							</div>
							<div class="metric-grid">
								{
									metrics.map((metric) => (
										<div class="metric-card">
											<strong>{metric.value}</strong>
											<span>{metric.label}</span>
										</div>
									))
								}
							</div>
						</div>

						<div class="hero-slide__panel">
							<p class="hero-panel__label">{slide.kicker}</p>
							<h2>{slide.title}</h2>
							<p>{slide.description}</p>
							<div class="hero-panel__footer">
								<span>{String(index + 1).padStart(2, "0")}</span>
								<span>/ {String(heroSlides.length).padStart(2, "0")}</span>
							</div>
						</div>
					</div>
				</article>
			))
		}
	</div>

	<div class="hero-carousel__controls site-shell">
		<div class="hero-carousel__dots">
			{
				heroSlides.map((slide, index) => (
					<button
						type="button"
						class:list={["hero-carousel__dot", index === 0 && "is-active"]}
						data-dot={index}
						aria-label={`Ver slide ${index + 1}: ${slide.kicker}`}
					/>
				))
			}
		</div>
	</div>
</section>

<script>
	const cleanupKey = "__puHeroCarouselCleanup";

	function mountCarousel() {
		const root = document.querySelector("[data-carousel]");
		if (!root) return;

		if (typeof root[cleanupKey] === "function") {
			root[cleanupKey]();
		}

		const slides = Array.from(root.querySelectorAll("[data-slide]"));
		const dots = Array.from(root.querySelectorAll("[data-dot]"));
		if (!slides.length || !dots.length) return;

		let current = 0;
		let timer = null;

		const render = (index) => {
			slides.forEach((slide, slideIndex) => {
				slide.classList.toggle("is-active", slideIndex === index);
			});
			dots.forEach((dot, dotIndex) => {
				dot.classList.toggle("is-active", dotIndex === index);
			});
			current = index;
		};

		const next = () => render((current + 1) % slides.length);
		const start = () => {
			if (timer) window.clearInterval(timer);
			timer = window.setInterval(next, 5200);
		};

		const handlers = dots.map((dot, index) => {
			const onClick = () => {
				render(index);
				start();
			};
			dot.addEventListener("click", onClick);
			return { dot, onClick };
		});

		render(0);
		start();

		root[cleanupKey] = () => {
			if (timer) window.clearInterval(timer);
			handlers.forEach(({ dot, onClick }) => dot.removeEventListener("click", onClick));
			delete root[cleanupKey];
		};
	}

	document.addEventListener("astro:page-load", mountCarousel);
	mountCarousel();
</script>
